NODE_ENV=production
PORT=4000

# Frontend autorizado para CORS. Separar multiples dominios con coma.
FRONTEND_URLS=https://app.tudominio.com

# Seguridad
AUTH_SECRET=reemplazar-por-un-secreto-de-32-caracteres-o-mas
AUTH_TOKEN_TTL=8h
AUTH_COOKIE_NAME=marisol_auth
SEED_DEFAULT_ADMIN=false
ADMIN_NAME=Administrador
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Base de datos
DATABASE_URL=postgres://usuario:password@host:5432/base
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_CA_CERT=
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_POOL_MAX=10

# Arranque / resiliencia
DB_STARTUP_RETRIES=6
DB_STARTUP_RETRY_DELAY_MS=5000

# Observabilidad
LOG_LEVEL=info

# Smoke tests post deploy
SMOKE_BASE_URL=https://api.tudominio.com
SMOKE_ADMIN_EMAIL=admin@tudominio.com
SMOKE_ADMIN_PASSWORD=reemplazar-por-credencial-segura
